{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Skill(weave-issue)",
            "Skill(weave-ship)",
            "Skill(rust-pre-commit)",
            "Skill(check-pr-review)",
            "Skill(weave-e2e)",
            "Skill(review-prs)"
        ]
    },
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-check.sh"
                    }
                ]
            }
        ]
    }
}
